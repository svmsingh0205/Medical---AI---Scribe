# ═══════════════════════════════════════════════════════════
# MediScribe.ai - Environment Configuration (FREE TIER)
# ═══════════════════════════════════════════════════════════

# Application
ENVIRONMENT=development
PORT=8000
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,https://*.vercel.app

# ─── AI SERVICES (ALL FREE) ───
# Groq (FREE - Fastest LLM + Whisper)
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio (FREE - 1M tokens/day, no card)
GOOGLE_API_KEY=your_google_ai_studio_key_here

# Together.ai (FREE $25 credit)
TOGETHER_API_KEY=your_together_api_key_here

# AssemblyAI (FREE $50 credit - for diarization)
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# ─── DATABASE & AUTH ───
# Supabase (FREE: 500MB DB + 2GB bandwidth)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ─── VECTOR STORE ───
# Pinecone (FREE: 1 index, 100K vectors)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here

# ─── STORAGE ───
# Cloudflare R2 (FREE: 10GB storage, 1M requests/month)
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
R2_BUCKET_NAME=mediscribe-audio
R2_ENDPOINT=your_r2_endpoint_here

# ─── QUEUE ───
# Upstash Redis (FREE: 10K requests/day)
UPSTASH_REDIS_URL=your_upstash_redis_url_here
UPSTASH_REDIS_TOKEN=your_upstash_redis_token_here

# ─── SECURITY ───
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── MONITORING ───
# Sentry (FREE: 5K errors/month)
SENTRY_DSN=your_sentry_dsn_optional

# ─── HIPAA COMPLIANCE ───
ENCRYPTION_KEY=your_encryption_key_here
AUDIT_LOG_RETENTION_DAYS=2555

# ═══════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS:
# 1. Sign up for all free services listed above
# 2. Copy this file to .env
# 3. Fill in your API keys
# 4. Never commit .env to git
# ═══════════════════════════════════════════════════════════
